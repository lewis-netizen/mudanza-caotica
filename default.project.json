{
  "name": "MudanzaCaotica",
  "tree": {
    "$className": "DataModel",

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "StreamingEnabled": false
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Systems": {
        "$path": "src/server"
      },
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": "Packages"
      },
      "Remotes": {
        "$className": "Folder",
        "Gameplay": {
          "$className": "Folder",
          "InteractObject": { "$className": "RemoteEvent" },
          "DeliverObject": { "$className": "RemoteEvent" },
          "ObjectStateChanged": { "$className": "RemoteEvent" }
        },
        "Round": {
          "$className": "Folder",
          "EventTriggered": { "$className": "RemoteEvent" },
          "RoundStarted": { "$className": "RemoteEvent" },
          "RoundEnded": { "$className": "RemoteEvent" },
          "TimerSync": { "$className": "RemoteEvent" }
        }
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$path": "src/client"
      }
    },

    "StarterGui": {
      "$path": "src/gui"
    }
  }
}
