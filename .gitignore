# Project place file
/Mudanza Caótica.rbxlx

# Roblox Studio lock files
/*.rbxlx.lock
/*.rbxl.lock

# Wally packages — instalados localmente, no se commitean
# wally.lock SÍ se commitea (equivalente a cargo.lock)
Packages/
ServerPackages/
DevPackages/

# Rokit — los binarios se instalan globalmente, no en el repo
# rokit.toml SÍ se commitea

# Sourcemap generado — se regenera con `rojo sourcemap`
sourcemap.json

# Std de selene para Roblox — selene lo autogenera (caché interna) cuando
# std = "roblox" y el CI lo regenera explícitamente. No se commitea.
roblox.yml

# VSCode — settings personales del desarrollador (no del proyecto)
# .vscode/settings.json y .vscode/extensions.json SÍ se commitean
.vscode/*.code-workspace
.vscode/launch.json

# Lefthook — overrides locales del desarrollador
lefthook-local.yml

# OS
.DS_Store
Thumbs.db.dgtest-sandbox/
